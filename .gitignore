# Environment
.env

# Session data (user audio, images, videos — never commit)
sessions/

# User-installed ComfyUI workflows (machine-specific, installed via Manage Workflows UI)
backend/comfyui/workflows/user/*.json
backend/comfyui/workflows/user/*.nodemap.json
# Keep the example stubs
!backend/comfyui/workflows/user/FADE_t2i.example
!backend/comfyui/workflows/user/FADE_i2v.example

# Model checkpoints (large binary files — download via setup_acestep.bat)
checkpoints/

# Logs
*.log

# Cache
.cache/

# Temporary / scratch files
tmp/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
acestep_venv/
*.pth

# Frontend build artifacts
frontend/node_modules/
frontend/dist/

# OS
.DS_Store
Thumbs.db
