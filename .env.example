# LLM — served through llama-swap
AGENT_URL=http://127.0.0.1:8000
AGENT_MODEL=qwen3.5-35b
OMNI_MODEL=Qwen2.5-Omni-7B

# Aligner — stable-ts (Whisper large-v3), auto-downloads, no path needed
# ALIGNER_MODEL_SIZE=large-v3

# ComfyUI
COMFYUI_URL=http://127.0.0.1:8188
COMFYUI_INPUT_DIR=C:/ComfyUI/input
COMFYUI_OUTPUT_DIR=C:/ComfyUI/output

# Service
SERVICE_PORT=8001
SESSION_DIR=./sessions

# Video backend: comfyui (default) | ltxdesktop (custom fork with num_frames patch)
# VIDEO_BACKEND=comfyui
# LTXDESKTOP_URL=http://127.0.0.1:8003
# LTXDESKTOP_PATH=C:/path/to/ltx-desktop-fork
# LTXDESKTOP_DATA_DIR=C:/path/to/ltxdesktop-data   # LTX_APP_DATA_DIR — models/outputs live here
#   Models required for I2V (~70GB total, download via huggingface-cli):
#     Lightricks/LTX-2.3  →  ltx-2.3-22b-distilled.safetensors (43GB)
#     Lightricks/LTX-2.3  →  ltx-2.3-spatial-upscaler-x2-1.0.safetensors (1.9GB)
#     Lightricks/gemma-3-12b-it-qat-q4_0-unquantized  →  folder (25GB)

# ACEStep local generator (Make a Song page)
# Run scripts/setup_acestep.bat (Windows) or setup_acestep.sh (Linux/Mac) once
# to create the dedicated ACEStep venv at ./acestep_venv/ — never installed globally.
# Installs from GitHub (PyPI sdist is broken — missing requirements.txt in build env).
# Default port 8001 conflicts with FADE — use 8002
ACESTEP_URL=http://127.0.0.1:8002
ACESTEP_CONFIG_PATH=acestep-v15-sft
ACESTEP_LM_MODEL_PATH=acestep-5Hz-lm-1.7B
# ACESTEP_VENV_DIR=./acestep_venv  # override if you placed the venv elsewhere

# Defaults (can be overridden per session at creation time)
# Orientation: portrait (1152x2048) or landscape (2048x1152)
DEFAULT_ORIENTATION=portrait
DEFAULT_FPS=25
SCENE_MIN_SECONDS=3
SCENE_MAX_SECONDS=10
